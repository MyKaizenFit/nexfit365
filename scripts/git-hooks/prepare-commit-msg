#!/bin/bash
# Strip Cursor agent attribution from commit messages (Linux).
MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0
sed -i \
  -e '/^Co-authored-by: Cursor <cursoragent@cursor.com>$/d' \
  -e '/^Co-authored-by: Cursor Agent <cursoragent@cursor.com>$/d' \
  -e '/cursoragent@cursor\.com/d' \
  -e '/^Made-with: Cursor$/d' \
  "$MSG_FILE"
