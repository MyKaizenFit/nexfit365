# Frontend Environment Variables
# Copy this file to .env.local and update the values

# API Configuration
# Para desarrollo local: usar puerto 8001
# Para producción: usar el dominio de producción
NEXT_PUBLIC_API_URL=http://localhost:8001/api

# App Configuration
NEXT_PUBLIC_APP_NAME=MyKaizenFit
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_DESCRIPTION=Tu compañero personal para alcanzar tus objetivos de fitness

# Development Configuration
NEXT_PUBLIC_DEBUG=true
NEXT_PUBLIC_LOG_LEVEL=debug

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_PWA=false
# Frontend Environment Variables
# Copy this file to .env.local and update the values

# API Configuration
# Para desarrollo local: usar puerto 8001
# Para producción: usar el dominio de producción
NEXT_PUBLIC_API_URL=http://localhost:8001/api

# App Configuration
NEXT_PUBLIC_APP_NAME=Nex-Fit
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_DESCRIPTION=Tu compañero personal para alcanzar tus objetivos de fitness

# Development Configuration
NEXT_PUBLIC_DEBUG=true
NEXT_PUBLIC_LOG_LEVEL=debug

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_PWA=false

# Google Drive Configuration (for exercise videos fallback)
# ID de la carpeta de Google Drive donde están los videos de ejercicios
# Carpeta: "Vídeos Nex+Fit" (Compartido conmigo)
NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=1dbDvVZKOwYJ4A13FtVslIid2JKLcN4fG
# Correo asociado a la carpeta compartida
NEXT_PUBLIC_GOOGLE_DRIVE_EMAIL=nex.fit.server@gmail.com

# Google Drive API Credentials (opcional, solo si usas la API para búsqueda automática)
# Para obtenerlas: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_DRIVE_API_KEY=
