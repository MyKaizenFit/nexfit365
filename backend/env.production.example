# Configuración de producción para MyKaizenFit Backend
# Este archivo se usa como referencia para configurar las variables en Render

# Django
DEBUG=False
SECRET_KEY=your-super-secret-key-here
ALLOWED_HOSTS=mykaizenfit-backend.onrender.com,localhost,127.0.0.1

# Base de datos (se configura automáticamente en Render)
DATABASE_URL=postgres://username:password@host:port/database

# Redis (se configura automáticamente en Render)
REDIS_URL=redis://username:password@host:port/database

# CORS
CORS_ALLOWED_ORIGINS=https://mykaizenfit.vercel.app,https://mykaizenfit.com
CORS_ALLOW_CREDENTIALS=True

# Archivos estáticos
STATIC_URL=/static/
STATIC_ROOT=/opt/render/project/src/staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=/opt/render/project/src/media/

# JWT
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=7

# Logging
LOG_LEVEL=INFO

# Cache
CACHE_TTL=300

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Email (opcional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Sentry (opcional)
SENTRY_DSN=























