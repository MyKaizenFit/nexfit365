# ============================================
# VARIABLES DE ENTORNO PARA DOCKER COMPOSE PRODUCCIÓN
# ============================================
# ⚠️ IMPORTANTE: 
# 1. Copia este archivo como .env.production (sin .template)
# 2. NO subir a Git (ya está en .gitignore)
# 3. Este archivo se usa por docker-compose.prod.yml para resolver ${VARIABLE}
#
# Las variables aquí definidas se resuelven ANTES de arrancar contenedores
# y se usan en docker-compose.prod.yml para servicios db, db-backup, redis

# ============================================
# POSTGRES
# ============================================
POSTGRES_DB=mykaizenfit
POSTGRES_USER=postgres
# ⚠️ CAMBIAR: Contraseña fuerte (mínimo 16 caracteres, mayúsculas, minúsculas, números, símbolos)
# ⚠️ DEBE SER LA MISMA que DB_PASSWORD en docker/backend.env.production
POSTGRES_PASSWORD=CHANGE-THIS-STRONG-PASSWORD-FOR-POSTGRES

# ============================================
# REDIS
# ============================================
# ⚠️ CAMBIAR: Contraseña fuerte para Redis
# ⚠️ DEBE SER LA MISMA que REDIS_PASSWORD en docker/backend.env.production
REDIS_PASSWORD=CHANGE-THIS-STRONG-PASSWORD-FOR-REDIS

# ============================================
# PUERTOS (Opcional - solo si no usas Nginx)
# ============================================
# Si usas Nginx como reverse proxy, estos puertos no se exponen
# Nginx escucha en 80/443 y redirige a estos servicios internamente
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================
# NOTAS
# ============================================
# - POSTGRES_PASSWORD debe coincidir con DB_PASSWORD en docker/backend.env.production
# - REDIS_PASSWORD debe coincidir con REDIS_PASSWORD en docker/backend.env.production
# - Estas variables se resuelven en docker-compose.prod.yml usando ${VARIABLE}
# - Los servicios db, db-backup y redis las usan directamente
# - Django lee DB_* desde docker/backend.env.production (env_file del servicio backend)

