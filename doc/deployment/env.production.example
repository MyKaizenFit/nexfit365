# Configuración de producción para MyKaizenFit
# Copia este archivo como .env.production y configura los valores

# Django
DEBUG=False
SECRET_KEY=your-super-secret-key-here
ALLOWED_HOSTS=mykaizenfit-backend.onrender.com,localhost,127.0.0.1

# Base de datos
DATABASE_URL=postgres://username:password@host:port/database

# Redis
REDIS_URL=redis://username:password@host:port/database

# CORS
CORS_ALLOWED_ORIGINS=https://mykaizenfit.vercel.app,https://mykaizenfit.com
CORS_ALLOW_CREDENTIALS=True

# Email (opcional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Sentry (opcional)
SENTRY_DSN=your-sentry-dsn-here

# JWT
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=7

# Archivos estáticos
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=/app/media/

# Logging
LOG_LEVEL=INFO

# Cache
CACHE_TTL=300

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

