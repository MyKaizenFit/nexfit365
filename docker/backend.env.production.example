# ============================================
# CONFIGURACIÓN DE PRODUCCIÓN - BACKEND
# ============================================
# ⚠️ IMPORTANTE: Este archivo contiene valores sensibles
# NO subir a Git. Añadir a .gitignore
# 
# INSTRUCCIONES:
# 1. Copia este archivo como backend.env.production
# 2. Reemplaza todos los valores marcados con ⚠️
# 3. Genera SECRET_KEY seguro: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 4. Configura tus dominios reales en ALLOWED_HOSTS y CORS

# ============================================
# DJANGO CORE
# ============================================
DEBUG=False
# ✅ SECRET_KEY GENERADO AUTOMÁTICAMENTE (50+ caracteres)
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_50_CHARS
# ✅ CONFIGURADO CON IP LOCAL (192.168.1.148) y IP PÚBLICA (45.136.19.91)
ALLOWED_HOSTS=192.168.1.148,45.136.19.91,localhost,127.0.0.1,api.nexfit365.dpdns.org,nexfit365.dpdns.org,www.nexfit365.dpdns.org

# ============================================
# BASE DE DATOS
# ============================================
# ⚠️ IMPORTANTE: POSTGRES_* se usa por docker-compose.prod.yml (servicios db y db-backup)
# DB_* se usa por Django (settings.py)
# Ambos deben tener los MISMOS valores

# Variables para Docker Compose (db y db-backup)
POSTGRES_DB=mykaizenfit
POSTGRES_USER=postgres
# ✅ CONTRASEÑA GENERADA AUTOMÁTICAMENTE (24 caracteres seguros)
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Variables para Django (settings.py)
DB_NAME=mykaizenfit
DB_USER=postgres
# ✅ MISMA CONTRASEÑA QUE POSTGRES_PASSWORD (para mantener la base de datos existente)
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=prefer

# ============================================
# REDIS
# ============================================
# ✅ CONTRASEÑA GENERADA AUTOMÁTICAMENTE (sin caracteres especiales problemáticos)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ============================================
# CORS Y SEGURIDAD
# ============================================
# ✅ CONFIGURADO CON IP PÚBLICA (45.136.19.91) y IP LOCAL (192.168.1.148)
# ⚠️ NOTA: Cuando añadas dominio, actualiza a HTTPS
CORS_ALLOWED_ORIGINS=http://45.136.19.91:3000,http://192.168.1.148:3000,http://localhost:3000,https://nexfit365.dpdns.org,https://www.nexfit365.dpdns.org
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://45.136.19.91:3000,http://192.168.1.148:3000,http://localhost:3000,https://nexfit365.dpdns.org,https://www.nexfit365.dpdns.org

# ============================================
# JWT (JSON Web Tokens)
# ============================================
# ✅ SECRETOS GENERADOS AUTOMÁTICAMENTE (32+ caracteres base64)
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ROTATE_REFRESH=True
JWT_BLACKLIST_AFTER_ROTATION=True

# ============================================
# ARCHIVOS ESTÁTICOS Y MEDIA
# ============================================
# ⚠️ NOTA: En settings.py, STATIC_ROOT está hardcodeado como "staticfiles"
# y MEDIA_ROOT usa UPLOAD_DIR (por defecto "media")
# Los volúmenes en docker-compose.prod.yml montan en /app/staticfiles y /app/media
# Esto está correcto y funciona bien
STATIC_URL=/static/
# STATIC_ROOT se define en settings.py como BASE_DIR / "staticfiles"
MEDIA_URL=/media/
# MEDIA_ROOT se define en settings.py como BASE_DIR / os.getenv("UPLOAD_DIR", "media")
# Si quieres cambiarlo, usa: UPLOAD_DIR=media

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=WARNING  # En producción, menos verbose que INFO

# ============================================
# EMAIL (Opcional - Configurar si usas emails)
# ============================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-password-app
# DEFAULT_FROM_EMAIL=noreply@tu-dominio.com

# ============================================
# SENTRY (Opcional - Para monitoreo de errores)
# ============================================
# SENTRY_DSN=https://tu-sentry-dsn@sentry.io/proyecto-id

# ============================================
# SEGURIDAD ADICIONAL
# ============================================
# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Cache TTL (segundos)
CACHE_TTL=300

# Session security
# ⚠️ NOTA: Si usas HTTP (sin HTTPS), cambia a False. Si usas HTTPS, mantén True
SESSION_COOKIE_SECURE=False  # Cambiar a True cuando uses HTTPS
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=False  # Cambiar a True cuando uses HTTPS

