# ============================================
# CONFIGURACIÓN DE PRODUCCIÓN - BACKEND
# ============================================
# Este archivo es un TEMPLATE. No contiene secretos reales.
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp backend.env.production.example backend.env.production
# 2. Rellena todos los valores marcados con CHANGE_ME_*
# 3. El archivo backend.env.production NO debe subirse a git (ya está en .gitignore)
#
# Generar SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Generar claves JWT / ENCRYPTION_KEY (base64 de 32 bytes):
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"

# ============================================
# DJANGO CORE
# ============================================
DEBUG=False
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_50_CHARS
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_BASE64_32BYTES
ALLOWED_HOSTS=localhost,127.0.0.1,tu-servidor.com,api.tu-dominio.com

# ============================================
# BASE DE DATOS
# ============================================
# POSTGRES_* lo usa docker-compose; DB_* lo usa Django. Deben tener los mismos valores.

POSTGRES_DB=mykaizenfit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

DB_NAME=mykaizenfit
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_HOST=nexfit-pro-db
DB_PORT=5432
DB_SSLMODE=prefer

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@nexfit-pro-redis:6379/0

# ============================================
# CORS Y SEGURIDAD
# ============================================
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
FRONTEND_URL=https://tu-dominio.com

# ============================================
# JWT (JSON Web Tokens)
# ============================================
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_ACCESS_TTL=120m
JWT_REFRESH_TTL=7d
JWT_ROTATE_REFRESH=True
JWT_BLACKLIST_AFTER_ROTATION=True

# ============================================
# ARCHIVOS ESTÁTICOS Y MEDIA
# ============================================
STATIC_URL=/static/
MEDIA_URL=/media/
PUBLIC_MEDIA_BASE_URL=https://api.tu-dominio.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=WARNING

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USER=CHANGE_ME_SMTP_EMAIL
SMTP_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD
DEFAULT_FROM_EMAIL=NexFit <CHANGE_ME_SMTP_EMAIL>

# ============================================
# PUSH NOTIFICATIONS (VAPID)
# ============================================
# Generar claves VAPID: pip install py-vapid && vapid --gen
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE_KEY
VAPID_CLAIM_EMAIL=CHANGE_ME_VAPID_EMAIL

# ============================================
# API EXTERNA - FATSECRET
# ============================================
FATSECRET_CLIENT_ID=CHANGE_ME_FATSECRET_CLIENT_ID
FATSECRET_CLIENT_SECRET=CHANGE_ME_FATSECRET_CLIENT_SECRET

# ============================================
# SEGURIDAD ADICIONAL
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
CACHE_TTL=300
MAX_UPLOAD_MB=300

SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# ============================================
# SENTRY (Opcional)
# ============================================
# SENTRY_DSN=https://tu-sentry-dsn@sentry.io/proyecto-id
