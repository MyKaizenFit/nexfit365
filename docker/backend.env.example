# ============================================
# DJANGO CORE
# ============================================
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.148,backend,45.136.19.91,api.nexfit365.dpdns.org,nexfit365.dpdns.org,www.nexfit365.dpdns.org

# ============================================
# BASE DE DATOS
# ============================================
# Variables para Django (settings.py)
DB_NAME=mykaizenfit_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=disable

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379/0
# En desarrollo no usamos contraseña para Redis

# ============================================
# CORS Y SEGURIDAD
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.148:3000,http://127.0.0.1:3000,http://45.136.19.91:3000,https://nexfit365.dpdns.org,https://www.nexfit365.dpdns.org
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://192.168.1.148:3000,http://127.0.0.1:3000,http://45.136.19.91:3000,https://nexfit365.dpdns.org,https://www.nexfit365.dpdns.org

# ============================================
# JWT (JSON Web Tokens)
# ============================================
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ROTATE_REFRESH=True
JWT_BLACKLIST_AFTER_ROTATION=True

# ============================================
# ARCHIVOS ESTÁTICOS Y MEDIA
# ============================================
STATIC_URL=/static/
MEDIA_URL=/media/

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=DEBUG  # En desarrollo, más verbose

# ============================================
# SEGURIDAD (Desarrollo - menos estricto)
# ============================================
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=False
